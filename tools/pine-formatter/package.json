{
    "name": "pine-formatter",
    "version": "0.1.0",
    "description": "Pine Script v6 formatter — enforces TradingView-safe style (120-char lines, correct wrap indentation)",
    "main": "dist/formatter.js",
    "types": "dist/formatter.d.ts",
    "bin": {
        "pine-format": "dist/cli.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "jest --passWithNoTests",
        "check": "node dist/cli.js --check"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^20.0.0",
        "jest": "^29.5.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.4.0"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/test"
        ],
        "testMatch": [
            "**/*.test.ts"
        ]
    }
}
