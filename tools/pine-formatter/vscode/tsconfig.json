{
    "compilerOptions": {
        "target":         "ES2020",
        "module":         "commonjs",
        "lib":            ["ES2020"],
        "outDir":         "./out",
        "rootDir":        "..",
        "strict":         true,
        "esModuleInterop": true,
        "skipLibCheck":   true,
        "sourceMap":      true
    },
    "include": [
        "src/**/*",
        "../src/**/*"
    ],
    "exclude": ["node_modules"]
}
